% Adds all theorems to the TOC
\newtheoremstyle{toc}
    {}
    {}
    %{\it}
    {}
    {}
    {\bf}
    {}
    { }
    {\thmname{#1}\thmnumber{ #2}.
    \phantomsection
    %\thmnote{: #3.\addcontentsline{toc}{subsubsection}{{\it#1}: #3}} }
    \thmnote{#3.}
    \phantomsection}
%\theoremstyle{toc}

\newcounter{problem}
\newenvironment{problem}[1][Problem]{
    \refstepcounter{problem}
    %\addcontentsline{toc}{subsubsection}{Problem \theproblem}
    \begin{trivlist}
    \item[\hskip\labelsep {\bfseries #1}\hskip \labelsep {\bfseries \theproblem. \hskip\labelsep}]
    %\itshape $ $
	$ $
}{\end{trivlist}}
% \counterwithin{problem}{section}
\providecommand*\problemautorefname{Problem}

\newenvironment{problem*}[1][Problem]{
    \begin{trivlist}
    \item[\hskip \labelsep {\bfseries #1}\hskip \labelsep ]
}{\end{trivlist}}

\newcounter{exercise}
\newenvironment{exercise}[1][Exercise]{
    \refstepcounter{exercise}
    %\addcontentsline{toc}{subsubsection}{Exercise \theexercise}
    \begin{trivlist}
    \item[\hskip\labelsep {\bfseries #1}\hskip \labelsep {\bfseries \theexercise. \hskip\labelsep}]
}{\end{trivlist}}
\counterwithin{exercise}{section}
\providecommand*\exerciseautorefname{Exercise}

\newtheorem{theorem}{Theorem}
\newtheorem*{theorem*}{Theorem}
\expandafter\providecommand\csname theoremautorefname\endcsname{Theorem}
\expandafter\providecommand\csname theorem*autorefname\endcsname{Theorem}

\newcommand{\newtheoremref}[2]{
	\newtheorem{#1}[theorem]{#2}
	\newtheorem*{#1*}{#2}
	\expandafter\providecommand\csname #1autorefname\endcsname{#2}
	\expandafter\providecommand\csname #1*autorefname\endcsname{#2}
}

\newtheoremref{lemma}{Lemma}
\newtheoremref{proposition}{Proposition}
\newtheoremref{corollary}{Corollary}
\newtheoremref{claim}{Claim}
\newtheoremref{conjecture}{Conjecture}

\theoremstyle{definition}
\newtheoremref{definition}{Definition}
\newtheoremref{fact}{Fact}
\newtheoremref{remark}{Remark}

\AtBeginEnvironment{proof}{\renewcommand{\qedsymbol}{$\square$}}
\newenvironment{solution*}{\begin{proof}[Solution] \renewcommand{\qedsymbol}{}$ $}{\end{proof}}
\newenvironment{solution}{\begin{proof}[Solution]$ $}{\end{proof}}

