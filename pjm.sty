\usepackage{common-math}

\newtheoremstyle{def}
    {}
    {}
    %{\it}
    {}
    {}
    {\bf}
    {}
    { }
    {\thmname{#1}\thmnumber{ #2}. }

\newcounter{example}[section]
\newenvironment{example}[1][Example]{
    \refstepcounter{example}
    %\addcontentsline{toc}{subsubsection}{Example \theexample}
    \begin{trivlist}
    \item[\hskip\labelsep {\bfseries #1.}\hskip \labelsep] %{\bfseries \theexample}]
}{\end{trivlist}}

\newtheorem{theorem}{Theorem}
\newtheorem*{theorem*}{Theorem}
\providecommand*\theoremautorefname{Theorem}
\numberwithin{theorem}{section}

\newtheorem{claim}{Claim}[section]
\providecommand*\claimautorefname{Claim}

\newtheorem{proposition}{Proposition}[section]
\newtheorem*{proposition*}{Proposition}
\providecommand*\propositionautorefname{Proposition}

\newtheorem{corollary}{Corollary}[theorem]
\providecommand*\corollaryautorefname{Corollary}
\numberwithin{corollary}{section}

\newtheorem{lemma}{Lemma}
\newtheorem*{lemma*}{Lemma}
\providecommand*\lemmaautorefname{Lemma}
\numberwithin{lemma}{section}

\newtheorem{question}{Question}
\newtheorem*{question*}{Question}
\providecommand*\lemmaautorefname{Question}
\numberwithin{question}{section}

\AtBeginEnvironment{proof}{\renewcommand{\qedsymbol}{$\square$}}
\newenvironment{solution*}{\begin{proof}[Solution] \renewcommand{\qedsymbol}{}$ $}{\end{proof}}
\newenvironment{solution}{\begin{proof}[Solution]$ $}{\end{proof}}

\theoremstyle{def}
\newtheorem{definition}{Definition}
\newtheorem*{definition*}{Definition}
\providecommand*\definitionautorefname{Definition}
\numberwithin{definition}{section}
